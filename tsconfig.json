{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "experimentalDecorators": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "noEmit": true,
    "outDir": "./dist",
    "paths": {
      "@/*": ["./src/*"],
      "@test/*": ["./test/*"]
    },
  },
  "include": ["src", "test", "rollup.config.js"],
  "exclude": ["node_modules", "dist", "examples"]
}