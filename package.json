{
  "name": "@noxy-network/browser-sdk",
  "version": "1.0.0",
  "description": "Secure, private, wallet-native push notifications for Web3.",
  "author": "Noxy Network",
  "license": "MIT",
  "keywords": [
    "noxy",
    "noxy-network",
    "push notifications",
    "web3",
    "ai",
    "agent",
    "crypto",
    "post quantum"
  ],
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/noxy-network/browser-sdk.git",
    "directory": "browser-sdk"
  },
  "type": "module",
  "main": "dist/bundle.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "rollup -c && cp src/kyber/kyber.wasm dist/kyber.wasm",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf node_modules && rm -rf dist",
    "typecheck": "tsc --noEmit",
    "prepare": "pnpm run build"
  },
  "dependencies": {
    "@scure/base": "^1.2.6",
    "@noble/ciphers": "^2.1.1",
    "@noble/curves": "^2.0.1",
    "@noble/ed25519": "^3.0.0",
    "@noble/hashes": "^2.0.1",
    "@polkadot/util-crypto": "^14.0.1",
    "idb": "^8.0.3",
    "json-with-bigint": "^3.5.2",
    "uuid": "^13.0.0",
    "viem": "^2.41.2",
    "zod": "^4.3.5",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@hpke/ml-kem": "^0.2.1",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.3.0",
    "@vitest/coverage-v8": "^4.0.16",
    "eslint": "^9.39.1",
    "fake-indexeddb": "^6.0.0",
    "happy-dom": "^20.1.0",
    "jiti": "^2.6.1",
    "rollup": "^4.53.3",
    "rollup-plugin-tsconfig-paths": "^1.5.2",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.49.0",
    "vitest": "^4.0.16"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  }
}
